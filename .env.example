# Frontend (optional — Vite dev proxy works without this)
# VITE_API_URL=http://localhost:8080

# Backend port
PORT=8080

# Backend — MongoDB Atlas
# Replace YOUR_PASSWORD_HERE with your Atlas database user password.
# Special characters in the password must be URL-encoded (e.g. @ becomes %40).
MONGODB_URI=mongodb+srv://vineethnaikeslavath_db_user:YOUR_PASSWORD_HERE@cluster0.9q2nvwe.mongodb.net/voucherpro?retryWrites=true&w=majority&appName=Cluster0

# Local MongoDB fallback (uncomment to use instead of Atlas)
# MONGODB_URI=mongodb://localhost:27017/voucherpro

# Backend — JWT (use a long random string in production)
JWT_SECRET=voucherpro-dev-secret-change-in-production-min-32-chars
JWT_EXPIRATION=86400000

# Backend — CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Backend — default admin user (seeded on first startup)
ADMIN_EMAIL=admin@voucherpro.com
ADMIN_PASSWORD=voucherpro-admin
ADMIN_NAME=VoucherPro Admin

# Backend — UPI QR code details (Manual PhonePe Verification Flow)
UPI_ID=8125139561@ybl
UPI_NAME=VoucherPro
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
